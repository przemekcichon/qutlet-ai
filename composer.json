{
    "name": "qutlet/qutlet-ai",
    "description": "Qutlet AI — provider-agnostyczna przeróbka opisów produktów (surowe → przerobione).",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Qutlet\\Ai\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse"
    }
}
